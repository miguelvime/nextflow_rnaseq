/*
 * nextflow.config
 * Configuración del pipeline RNA-seq GSE52778
 *
 */

params {
    samplesheet    = "${projectDir}/assets/samplesheet_test.csv"
    datadir        = "${projectDir}/../data/"
    genome_fasta   = "${projectDir}/../data/genome/Homo_sapiens.GRCh38.dna.primary_assembly.fa"
    genome_gtf     = "${projectDir}/../data/genome/Homo_sapiens.GRCh38.111.gtf"
    star_index_dir = "${projectDir}/../data/star_index"
    outdir         = "${projectDir}/../results"
}

profiles {
    
    // Entorno 1: Ejecución local con Docker (para desarrollo y testeo)
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.executor  = 'local'
        
        process {
            cpus   = 2
            memory = '4.GB'
            time   = '4.h'
            
            withName: '.*STAR_INDEX.*' {
                cpus     = 4
                memory   = '13.GB'
                time     = '8.h'
                maxForks = 1 
            }
            withName: '.*STAR_ALIGN.*' {
                cpus     = 2
                memory   = '4.GB'
                // Inyección del límite de RAM estrictamente para sobrevivir en local
                ext.args = '--limitBAMsortRAM 1000000000' 
            }
            withName: '.*SAMTOOLS.*' {
                cpus   = 4
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*PICARD_MARKDUP.*' {
                cpus   = 2
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*FEATURECOUNTS.*' {
                cpus   = 4
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*MULTIQC.*' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
            withName: '.*RNASEQ_R.*' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
        }
    }

    // Entorno 2: Despliegue en HPC Picasso (SCBI-UMA) — Singularity + Slurm
    picasso {
        singularity.enabled    = true
        singularity.autoMounts = true
        // Las imágenes Docker se convierten automáticamente a .sif y se cachean aquí.
        // Usar $HOME para que el caché persista entre ejecuciones (FSCRATCH se purga).
        singularity.cacheDir   = "$HOME/UEM/nextflow_rnaseq/.singularity_cache"

        // Cada proceso Nextflow se envía como un trabajo Slurm independiente.
        process.executor = 'slurm'
        // Si las imágenes ya están en caché, no se necesita internet. Si no, aumentar timeout.
        singularity.pullTimeout = '40m'

        process {
            // Recursos por defecto para procesos ligeros (FastQC, featureCounts, MultiQC…)
            cpus           = 4
            memory         = '16.GB'
            time           = '4.h'
            // Cola general de Picasso; ajusta si tu grupo tiene una cola dedicada.
            clusterOptions = '--partition=general'

            withName: '.*FASTQC.*' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
            withName: '.*TRIMMOMATIC.*' {
                cpus   = 4
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*STAR_INDEX.*' {
                // Indexación del genoma humano completo (GRCh38 primary assembly, ~3.1 GB).
                // Requiere ≥32 GB RAM. Se usa el genoma completo; NO se recortan cromosomas.
                cpus           = 12
                memory         = '64.GB'
                time           = '8.h'
                clusterOptions = '--partition=general'
            }
            withName: '.*STAR_ALIGN.*' {
                // Alineamiento paired-end con genoma completo.
                // Sin --limitBAMsortRAM: STAR puede usar toda la RAM asignada para ordenar el BAM.
                cpus           = 12
                memory         = '45.GB'
                time           = '4.h'
                clusterOptions = '--partition=general'
            }
            withName: '.*SAMTOOLS.*' {
                cpus   = 4
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*PICARD_MARKDUP.*' {
                cpus   = 2
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*FEATURECOUNTS.*' {
                cpus   = 4
                memory = '8.GB'
                time   = '2.h'
            }
            withName: '.*MULTIQC.*' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
            withName: '.*RNASEQ_R.*' {
                cpus   = 2
                memory = '4.GB'
                time   = '1.h'
            }
        }
    }
}